# NEWS_RESEARCH_PROVIDER=gdelt
# NEWS_RESEARCH_PROVIDER=yfinance
# NEWS_RESEARCH_PROVIDER=openalex
ENABLE_LIVE_TRADING=false
LLM_PROVIDER=disabled
